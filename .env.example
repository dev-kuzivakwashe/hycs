# Copy this file to .env and fill in your own values.
# NEVER commit the real .env file. It is gitignored.

# ---------------------------------------------------------------------------
# Lovable Cloud / Backend (publishable, safe to expose in the browser bundle)
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxxxx"
VITE_SUPABASE_PROJECT_ID="your-project-ref"

# Server-side mirrors of the above (used by server functions / SSR).
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxxxx"

# Service role key. SERVER ONLY. Bypasses RLS. Never expose to the client.
# Not available on Lovable Cloud managed projects.
SUPABASE_SERVICE_ROLE_KEY="sb_secret_xxxxxxxxxxxxxxxxxxxxxx"

# Optional: direct Postgres connection string used by some tooling.
DATABASE_URL="postgresql://user:password@host:5432/postgres"

# ---------------------------------------------------------------------------
# Lovable AI Gateway (default model provider used when no BYOK key is set)
# ---------------------------------------------------------------------------
LOVABLE_API_KEY="lov_xxxxxxxxxxxxxxxxxxxxxx"

# ---------------------------------------------------------------------------
# Image search providers (optional, server-side only)
# Used by src/lib/fetch-image.functions.ts when generating projects.
# ---------------------------------------------------------------------------
PEXELS_API_KEY=""
PIXABAY_API_KEY=""

# ---------------------------------------------------------------------------
# Payments (optional, only if Stripe is enabled)
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxx"

# ---------------------------------------------------------------------------
# Notes
# ---------------------------------------------------------------------------
# - BYOK provider keys (Groq / OpenAI / Gemini / Claude) are entered through
#   the in-app Settings page and stored in the browser. They are NOT read
#   from this file.
# - GitHub Personal Access Tokens used by the deploy feature are also stored
#   client-side via Settings and never committed.
